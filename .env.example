# Local credentials — keep this file only on your Mac (gitignored).
# Setup:
#   cp .env.example .env
#   # then replace the placeholder AWS values below
#
# Never commit .env.

# --- AWS (required for Spark → S3 streaming) ---
# Use real credentials — do not leave the placeholder values below.
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
# Optional — only needed for temporary/session credentials (e.g. SSO, assumed role)
# AWS_SESSION_TOKEN=

AWS_REGION=us-east-1

# --- Kafka (producer + Spark consumer) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=iot_sensors

# Spark consumer only — "latest" skips existing messages; use "earliest" to backfill
KAFKA_STARTING_OFFSETS=latest

# --- S3 sink (Spark streaming output) ---
S3_BUCKET=real-time-processing-kafka-sink
S3_OUTPUT_PREFIX=new_iot_streaming_data/
S3_CHECKPOINT_PREFIX=new_checkpoints/iot_streaming_data/
S3_DEAD_LETTER_PREFIX=new_dead_letter/iot_streaming_data/
S3_DEAD_LETTER_CHECKPOINT_PREFIX=new_checkpoints/dead_letter/iot_streaming_data/

# --- Spark streaming ---
SPARK_TRIGGER_INTERVAL=30 seconds

# --- Logging (optional) ---
# LOG_DIR=logs
